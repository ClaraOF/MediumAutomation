# Copiá este archivo como .env y completá tus keys
# cp .env.example .env

# ==== API Keys ====
NEWSAPI_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# ==== Modelos OpenRouter ====
OPENROUTER_MODEL_RELEVANCE=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_MODEL_SUMMARY=stepfun/step-3.5-flash:free

# ==== Modelos OpenAI ====
OPENAI_MODEL_RELEVANCE=gpt-4o-mini
OPENAI_MODEL_SUMMARY=gpt-4o-mini

# ==== Azure OpenAI (opcional) ====
AZURE_API_KEY=
AZURE_ENDPOINT=
AZURE_DEPLOYMENT_RELEVANCE=
AZURE_DEPLOYMENT_SUMMARY=
AZURE_API_VERSION=2024-02-01
